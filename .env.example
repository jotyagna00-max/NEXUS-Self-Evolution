# NEXUS Self-Evolution — Environment Configuration
#
# NEXUS runs fully offline with a local LLM. No cloud API keys are needed.
# The only required configuration is a local LLM server (LM Studio / Ollama)
# running at http://localhost:1234/v1 (configurable in Settings).

# APP_URL: The URL where this applet is hosted (used for self-referential links).
APP_URL="http://localhost:3000"
