{
  "name": "nexus-self-evolution",
  "private": true,
  "version": "1.26.0",
  "description": "NEXUS Self-Evolution System",
  "author": "Mindraxus <jotyagna00-max@users.noreply.github.com>",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "npx rimraf dist",
    "lint": "tsc --noEmit",
    "build:win": "npm run build && electron-builder --win",
    "download:model": "node scripts/download-model.js"
  },
  "build": {
    "appId": "com.nexus.self-evolution",
    "productName": "NEXUS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "electronDist": "node_modules/electron/dist",
    "extraResources": [
      {
        "from": "llama-models",
        "to": "llama-models",
        "filter": [
          "*.gguf"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.84",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "node-llama-cpp": "^3.19.0",
    "openai": "^6.42.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
